# Django Core
SECRET_KEY=django-insecure-replace-with-a-real-secret-key-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQLite (default) — override for Postgres
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=deployctrl
# DB_USER=postgres
# DB_PASSWORD=yourpassword
# DB_HOST=localhost
# DB_PORT=5432

# MongoDB — users & RBAC
MONGO_URI=mongodb://localhost:27017/deployctrl
MONGO_DB=deployctrl

# JWT
JWT_ACCESS_HOURS=8
JWT_REFRESH_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
